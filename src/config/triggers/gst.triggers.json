{
  "version": 1,
  "triggers": [
    {
      "documentType": "GST",
      "field": "gstReturnRegistrationNo",
      "triggerType": "required",
      "errorMessage": "GST return registration number is required",
      "order": 1
    },
    {
      "documentType": "GST",
      "field": "gstReturnRegistrationNo",
      "triggerType": "regex",
      "condition": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$",
      "errorMessage": "Invalid GSTIN format",
      "order": 2
    },
    {
      "documentType": "GST",
      "field": "pan",
      "triggerType": "required",
      "errorMessage": "PAN is required for GST validation",
      "order": 3
    },
    {
      "documentType": "GST",
      "field": "pan",
      "triggerType": "regex",
      "condition": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
      "errorMessage": "Invalid PAN format in GST",
      "order": 4
    },
    {
      "documentType": "GST",
      "field": "gstReturnRegistrationNo",
      "triggerType": "custom",
      "customKey": "gstPanMatchesPan",
      "secondaryField": "pan",
      "errorMessage": "GSTIN PAN does not match provided PAN",
      "order": 5
    }
  ]
}
